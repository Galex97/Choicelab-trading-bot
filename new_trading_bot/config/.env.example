# ============================================================
# 东方财富A股争霸赛自动交易机器人 - 环境变量模板
# 使用方法：复制此文件为 .env 并填入实际值
#   copy .env.example .env
# ============================================================

# --- LLM API 配置 ---
# OpenAI API Key（使用 OpenAI 时填写）
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepSeek API Key（使用 DeepSeek 时填写）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# API Base URL（可选，使用第三方代理或 DeepSeek 时填写）
# DeepSeek 示例: https://api.deepseek.com/v1
# OpenAI 兼容代理示例: https://api.openai-proxy.com/v1
BASE_URL=

# 使用的模型名称
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-reasoner
LLM_MODEL=gpt-4o

# LLM 温度参数（0-1，越低越稳定）
LLM_TEMPERATURE=0.3

# --- 通知配置（预留） ---
# WECHAT_WEBHOOK=
# DINGTALK_WEBHOOK=
